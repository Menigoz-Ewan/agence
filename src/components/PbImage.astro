---
interface Props {
  record: { [key: string]: any };
  imageField: string;
}

const { record, imageField } = Astro.props;

// 1. On gère le cas où PocketBase renverrait un tableau d'images au lieu d'une seule
const nomFichier = Array.isArray(record[imageField])
  ? record[imageField][0]
  : record[imageField];

// 2. On fabrique le lien
const imageURL = `http://127.0.0.1:8090/api/files/${record.collectionId}/${record.id}/${nomFichier}`;
---

<div
  style="border: 2px solid red; padding: 10px; margin: 10px; font-size: 12px; word-break: break-all;"
>
  <p>
    <b>LIEN GÉNÉRÉ :</b>
    <a href={imageURL} target="_blank" style="color: blue;">{imageURL}</a>
  </p>

  {
    nomFichier ? (
      <img
        src={imageURL}
        alt="Test"
        style="width: 100%; max-height: 200px; object-fit: cover;"
      />
    ) : (
      <p>⚠️ Aucune image trouvée dans record.{imageField}</p>
    )
  }
</div>
