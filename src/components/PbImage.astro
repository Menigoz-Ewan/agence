---
import pb from "../utils/pb";
import { Image } from "astro:assets";

interface Props {
  record: { [key: string]: any }; // The record containing the image
  imageField: string; // The field name for the image in the record
}

const { record, imageField } = Astro.props;

const imageURL = pb.files.getURL(record, record[imageField]);
---

{
  imageURL && (
    <img
      src={imageURL}
      alt={record.nomMaison || "Image"}
      loading="lazy"
      decoding="async"
      style="width: 100%; height: auto;"
    />
  )
}
