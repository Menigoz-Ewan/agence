---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../utils/pb";

const agents = await getAgents();
---

<Layout title="Liste de nos agents">
    <div class="max-w-7xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-8 text-gray-900">Nos Agents</h1>

        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                agents.map((agent) => (
                    <li class="border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
                        <a href={`/agents/${agent.id}`} class="block">
                            <h2 class="text-xl font-semibold">
                                {agent.prenom} {agent.nom}
                            </h2>
                            <p class="text-gray-500 text-sm mt-1">
                                {agent.email_agent}
                            </p>
                            <p class="text-blue-500 mt-4 font-medium">
                                Voir ses offres →
                            </p>
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</Layout>
